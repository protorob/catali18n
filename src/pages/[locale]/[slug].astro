---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const { locale = 'it', slug } = Astro.params;

if (!slug) {
  return Astro.redirect(`/${locale}`);
}

// Fetch the localized markdown file
// Example: src/content/pages/en/about.md maps to collection 'pages', id 'en/about'
const entry = await getEntry('pages', `${locale}/${slug}`);

if (!entry) {
  // If the page doesn't exist, redirect to localized homepage
  return Astro.redirect(`/${locale}`);
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description} pageTitle={entry.data.title} pageDescription={entry.data.description}>
  <div class="max-w-3xl py-10">
    <div class="prose-custom">
      <Content />
    </div>
  </div>
</Layout>

<style is:global>
  /* Custom typography styling for rendered Markdown to keep design premium without requiring @tailwindcss/typography */
  .prose-custom h1 {
    display: none; /* title is shown in the page banner */
  }
  .prose-custom h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--foreground);
    border-bottom: 1px solid rgba(var(--border), 0.4);
    padding-bottom: 0.5rem;
  }
  .prose-custom h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom p {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--foreground);
    opacity: 0.9;
    font-weight: 300;
  }
  .prose-custom ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  .prose-custom li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose-custom a {
    color: var(--primary);
    text-decoration: underline;
    font-weight: 500;
  }
  .prose-custom a:hover {
    color: var(--primary-hover);
  }
  .prose-custom strong {
    font-weight: 600;
    color: var(--foreground);
  }
</style>
