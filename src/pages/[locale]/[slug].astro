---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const { locale = 'it', slug } = Astro.params;

if (!slug) {
  return Astro.redirect(`/${locale}`);
}

// Fetch the localized markdown file
// Example: src/content/pages/en/about.md maps to collection 'pages', id 'en/about'
const entry = await getEntry('pages', `${locale}/${slug}`);

if (!entry) {
  // If the page doesn't exist, redirect to localized homepage
  return Astro.redirect(`/${locale}`);
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <div class="max-w-3xl mx-auto py-12">
    
    <!-- Breadcrumbs -->
    <nav class="flex mb-8 text-xs font-semibold text-gray-500 uppercase tracking-wider" aria-label="Breadcrumb">
      <a href={`/${locale}`} class="hover:text-brand-primary transition-colors">Home</a>
      <span class="mx-2 text-gray-400">/</span>
      <span class="text-gray-700 dark:text-gray-300">{entry.data.title}</span>
    </nav>

    <!-- Document wrapper -->
    <article class="bg-app-card border border-app-border/60 rounded-3xl p-8 md:p-12 shadow-md transition-theme">
      
      <!-- Custom Styled HTML Render -->
      <div class="prose-custom">
        <Content />
      </div>

    </article>
  </div>
</Layout>

<style is:global>
  /* Custom typography styling for rendered Markdown to keep design premium without requiring @tailwindcss/typography */
  .prose-custom h1 {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
    background: linear-gradient(to right, var(--primary), var(--accent));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
  .prose-custom h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--foreground);
    border-bottom: 1px solid rgba(var(--border), 0.4);
    padding-bottom: 0.5rem;
  }
  .prose-custom h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom p {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--foreground);
    opacity: 0.9;
    font-weight: 300;
  }
  .prose-custom ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  .prose-custom li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose-custom a {
    color: var(--primary);
    text-decoration: underline;
    font-weight: 500;
  }
  .prose-custom a:hover {
    color: var(--primary-hover);
  }
  .prose-custom strong {
    font-weight: 600;
    color: var(--foreground);
  }
</style>
