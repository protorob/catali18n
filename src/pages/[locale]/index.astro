---
import Layout from '../../layouts/Layout.astro';
import { pb } from '../../lib/pocketbase';
import { getTranslations } from '../../lib/translations';

// In SSR mode, we retrieve the locale from params
const { locale = 'it' } = Astro.params;
const t = getTranslations(locale);

let categories = [];
let featuredProducts = [];

try {
  // 1. Fetch the language ID for this locale code
  const langRecord = await pb.collection('languages').getFirstListItem(`code="${locale}"`);
  
  // 2. Fetch localized categories
  categories = await pb.collection('categories_i18n').getFullList({
    filter: `language="${langRecord.id}"`,
    expand: 'record',
  });

  // 3. Fetch some localized products for a featured section
  featuredProducts = await pb.collection('products_i18n').getList(1, 6, {
    filter: `language="${langRecord.id}"`,
    expand: 'record,record.category',
  });
  featuredProducts = featuredProducts.items;
} catch (err) {
  console.warn("PocketBase empty or not started. Rendering fallback mock data.");
  
  // High-fidelity fallback category list
  categories = [
    {
      name: locale === 'it' ? 'Elettronica Industriale' : 'Industrial Electronics',
      slug: 'electronics',
      description: locale === 'it' ? 'Dispositivi e componenti elettronici avanzati per automazione.' : 'Advanced electronic devices and components for automation.',
      expand: {
        record: {
          id: 'fallback_cat_1',
          cat_banner: '',
        }
      }
    },
    {
      name: locale === 'it' ? 'Attrezzature & Macchinari' : 'Equipment & Machinery',
      slug: 'machinery',
      description: locale === 'it' ? 'Macchinari di precisione per catene di montaggio industriali.' : 'Precision machinery for industrial assembly lines.',
      expand: {
        record: {
          id: 'fallback_cat_2',
          cat_banner: '',
        }
      }
    },
    {
      name: locale === 'it' ? 'Componentistica Plastica' : 'Plastic Components',
      slug: 'plastics',
      description: locale === 'it' ? 'Muffe, raccordi e particolari in plastica ad alta resistenza.' : 'High-strength plastic molds, fittings, and details.',
      expand: {
        record: {
          id: 'fallback_cat_3',
          cat_banner: '',
        }
      }
    }
  ];

  // High-fidelity fallback products list
  featuredProducts = [
    {
      name: 'PLC Controller H100',
      prod_title: 'Programmable Logic Controller H100',
      slug: 'plc-controller-h100',
      prod_description: 'Industrial grade PLC with 16 inputs and 12 outputs.',
      expand: {
        record: {
          id: 'fallback_prod_1',
          product_sku: 'PLC-H100-XYZ',
          product_ean: '8012345678901'
        }
      }
    },
    {
      name: 'Sensore Laser L20',
      prod_title: 'Laser Distance Sensor L20',
      slug: 'laser-sensor-l20',
      prod_description: 'High precision laser distance sensor, range up to 20m.',
      expand: {
        record: {
          id: 'fallback_prod_2',
          product_sku: 'SEN-L20-LAS',
          product_ean: '8012345678902'
        }
      }
    }
  ];
}

// Helper to resolve PocketBase image URL or provide CSS gradient placeholder
function getCategoryImage(cat: any) {
  const record = cat.expand?.record;
  if (record && record.cat_banner) {
    return pb.files.getURL(record, record.cat_banner);
  }
  // Return null to trigger elegant CSS gradient cards
  return null;
}

// Preset modern color gradients for cards
const gradients = [
  'from-blue-600 to-indigo-700 dark:from-blue-900 dark:to-indigo-950',
  'from-emerald-600 to-teal-700 dark:from-emerald-900 dark:to-teal-950',
  'from-purple-600 to-pink-700 dark:from-purple-900 dark:to-pink-950',
  'from-amber-600 to-orange-700 dark:from-amber-900 dark:to-orange-950',
];
---

<Layout title={t.nav.home}>
  
  <!-- Hero Section -->
  <section class="relative rounded-3xl overflow-hidden mb-16 py-20 px-8 md:px-16 bg-linear-to-r from-blue-700 to-indigo-900 dark:from-slate-900 dark:to-blue-950 text-white shadow-xl">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    <div class="relative max-w-2xl">
      <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-semibold bg-white/10 text-blue-200 mb-6 backdrop-blur-md">
        ✨ Astro + PocketBase Powered
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6 animate-fade-in leading-tight">
        {t.hero.title}
      </h1>
      <p class="text-lg md:text-xl text-blue-100 mb-8 font-light leading-relaxed">
        {t.hero.subtitle}
      </p>
      <a
        href="#categories-section"
        class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-blue-700 bg-white hover:bg-blue-50 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-offset-blue-700 focus:ring-white transition-all shadow-md hover:scale-102"
      >
        {t.hero.cta}
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2 animate-bounce-horizontal">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="categories-section" class="scroll-mt-24 mb-16">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl font-bold tracking-tight">{t.nav.categories}</h2>
        <p class="text-sm text-gray-500 mt-1">{t.product.browseProductsSub}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {categories.map((cat, idx) => {
        const bgGradient = gradients[idx % gradients.length];
        const imageUrl = getCategoryImage(cat);
        return (
          <a
            href={`/${locale}/category/${cat.slug}`}
            class="group relative flex flex-col justify-end h-80 rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
          >
            {imageUrl ? (
              <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105" style={`background-image: url('${imageUrl}')`}></div>
            ) : (
              <div class={`absolute inset-0 bg-gradient-to-br ${bgGradient} transition-transform duration-500 group-hover:scale-105`}></div>
            )}
            
            <!-- Frosted overlay for content readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
            
            <div class="relative p-6 text-white z-10">
              <h3 class="text-xl font-bold mb-2 group-hover:text-blue-300 transition-colors">
                {cat.name}
              </h3>
              <p class="text-xs text-gray-300 line-clamp-2 font-light">
                {cat.description?.replace(/<[^>]*>/g, '') || ''}
              </p>
              <span class="inline-flex items-center text-xs font-semibold text-blue-300 mt-4 group-hover:translate-x-1.5 transition-transform">
                {t.product.browseCatalog}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 ml-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Featured Products Section -->
  <section class="mb-8">
    <div class="border-t border-app-border/40 pt-16">
      <div class="mb-8">
        <h2 class="text-3xl font-bold tracking-tight">{t.product.featuredProducts}</h2>
        <p class="text-sm text-gray-500 mt-1">{t.product.featuredProductsSub}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProducts.map((prod) => (
          <div class="flex flex-col bg-app-card border border-app-border/60 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-200">
            <div class="h-48 bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 flex items-center justify-center p-4">
              <!-- Render modern icon/placeholder since there are no images on base product -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-400 dark:text-gray-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
              </svg>
            </div>
            <div class="flex-grow p-6 flex flex-col justify-between">
              <div>
                <span class="text-[10px] uppercase font-bold tracking-wider text-brand-primary">
                  {prod.expand?.record?.product_sku || 'SKU-PENDING'}
                </span>
                <h3 class="text-lg font-bold mt-1 text-app-fg line-clamp-1">
                  {prod.name || prod.prod_title}
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 line-clamp-2 font-light">
                  {prod.prod_description?.replace(/<[^>]*>/g, '') || ''}
                </p>
              </div>
              <div class="mt-6 pt-4 border-t border-app-border/40 flex justify-between items-center">
                <a
                  href={`/${locale}/product/${prod.slug}`}
                  class="text-sm font-semibold text-brand-primary hover:text-brand-hover inline-flex items-center"
                >
                  {t.product.productDetails}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 ml-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
