---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../lib/translations';

const { locale = 'it' } = Astro.params;
const t = getTranslations(locale);
---

<Layout title={t.cart.title}>
  <div class="py-6 max-w-5xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight mb-8">{t.cart.title}</h1>

    <!-- Two columns: Left for products, Right for quotation details -->
    <div id="cart-container" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column: Cart Items -->
      <div class="lg:col-span-2 space-y-4">
        <div id="cart-items-list" class="space-y-4">
          <!-- Dynamically populated by client-side JS -->
        </div>

        <!-- Empty state fallback -->
        <div id="cart-empty-state" class="hidden text-center py-16 bg-app-card border border-app-border border-dashed rounded-3xl p-6">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 mx-auto text-gray-400 mb-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
          <p class="text-gray-500 font-light mb-6">{t.cart.empty}</p>
          <a href={`/${locale}`} class="inline-flex px-5 py-2.5 bg-brand-primary text-white text-sm font-semibold rounded-xl hover:bg-brand-hover transition-colors">
            {locale === 'it' ? 'Torna al Catalogo' : 'Back to Catalog'}
          </a>
        </div>
      </div>

      <!-- Right Column: Quotation Form -->
      <div id="cart-form-container" class="lg:col-span-1">
        <div class="bg-app-card border border-app-border/60 rounded-3xl p-6 md:p-8 shadow-md sticky top-24">
          <h2 class="text-xl font-bold mb-6">{locale === 'it' ? 'Dettagli Richiesta' : 'Request Details'}</h2>
          
          <form id="quotation-form" class="space-y-4">
            <div>
              <label for="client-name" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.name} *</label>
              <input type="text" id="client-name" required class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all" />
            </div>

            <div>
              <label for="client-email" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.email} *</label>
              <input type="email" id="client-email" required class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all" />
            </div>

            <div>
              <label for="client-company" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.company}</label>
              <input type="text" id="client-company" class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all" />
            </div>

            <div>
              <label for="client-address" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.address}</label>
              <input type="text" id="client-address" class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all" />
            </div>

            <div>
              <label for="client-phone" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.phone}</label>
              <input type="tel" id="client-phone" class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all" />
            </div>

            <div>
              <label for="client-notes" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{t.cart.notes}</label>
              <textarea id="client-notes" rows="3" class="w-full px-4 py-2.5 rounded-xl border border-app-border bg-app-bg text-sm focus:outline-hidden focus:ring-2 focus:ring-brand-primary transition-all resize-none"></textarea>
            </div>

            <button type="submit" class="w-full mt-4 py-3.5 bg-brand-primary hover:bg-brand-hover text-white font-semibold rounded-xl text-sm transition-all shadow-md active:scale-98">
              {t.cart.submit}
            </button>
          </form>
        </div>
      </div>

    </div>

    <!-- Success state overlay -->
    <div id="cart-success-state" class="hidden text-center py-20 bg-app-card border border-app-border rounded-3xl p-8 max-w-lg mx-auto shadow-lg animate-fade-in">
      <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold mb-4">{t.cart.success}</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 font-light mb-8">
        {locale === 'it' 
          ? 'Il nostro team vendite analizzerà la tua richiesta e ti contatterà al più presto.' 
          : 'Our sales team will analyze your request and get back to you shortly.'}
      </p>
      <a href={`/${locale}`} class="inline-flex px-6 py-3 bg-brand-primary text-white text-sm font-semibold rounded-xl hover:bg-brand-hover transition-colors">
        {locale === 'it' ? 'Torna alla Home' : 'Back to Home'}
      </a>
    </div>

  </div>
</Layout>

<script>
  interface CartItem {
    id: string;
    name: string;
    sku: string;
    quantity: number;
  }

  function getCart(): CartItem[] {
    try {
      return JSON.parse(localStorage.getItem('cart') || '[]');
    } catch {
      return [];
    }
  }

  function saveCart(cart: CartItem[]) {
    localStorage.setItem('cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('cart-updated'));
  }

  function renderCart() {
    const listContainer = document.getElementById('cart-items-list');
    const emptyState = document.getElementById('cart-empty-state');
    const formContainer = document.getElementById('cart-form-container');
    const cart = getCart();

    if (!listContainer) return;
    listContainer.innerHTML = '';

    if (cart.length === 0) {
      emptyState?.classList.remove('hidden');
      formContainer?.classList.add('hidden');
      return;
    }

    emptyState?.classList.add('hidden');
    formContainer?.classList.remove('hidden');

    cart.forEach((item, index) => {
      const itemRow = document.createElement('div');
      itemRow.className = 'flex flex-col sm:flex-row items-start sm:items-center justify-between p-4 bg-app-card border border-app-border/60 rounded-2xl gap-4 transition-theme shadow-xs';
      
      itemRow.innerHTML = `
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-linear-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 rounded-xl flex items-center justify-center p-1 border border-app-border/40">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-6 h-6 text-gray-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-app-fg text-sm">${item.name}</h3>
            <p class="text-[10px] text-gray-500 font-mono mt-0.5">SKU: ${item.sku}</p>
          </div>
        </div>

        <div class="flex items-center space-x-6 w-full sm:w-auto justify-between sm:justify-end">
          <div class="flex items-center border border-app-border rounded-xl overflow-hidden bg-app-bg">
            <button class="dec-qty p-2 text-gray-500 font-bold hover:bg-app-card" data-idx="${index}">&minus;</button>
            <span class="w-8 text-center text-xs font-semibold">${item.quantity}</span>
            <button class="inc-qty p-2 text-gray-500 font-bold hover:bg-app-card" data-idx="${index}">&plus;</button>
          </div>
          <button class="remove-item text-xs font-semibold text-red-500 hover:text-red-600 transition-colors" data-idx="${index}">
            Remove
          </button>
        </div>
      `;

      listContainer.appendChild(itemRow);
    });

    // Event bindings for dynamically rendered rows
    listContainer.querySelectorAll('.dec-qty').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-idx') || '0');
        const cart = getCart();
        if (cart[idx].quantity > 1) {
          cart[idx].quantity -= 1;
          saveCart(cart);
          renderCart();
        }
      });
    });

    listContainer.querySelectorAll('.inc-qty').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-idx') || '0');
        const cart = getCart();
        cart[idx].quantity += 1;
        saveCart(cart);
        renderCart();
      });
    });

    listContainer.querySelectorAll('.remove-item').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-idx') || '0');
        const cart = getCart();
        cart.splice(idx, 1);
        saveCart(cart);
        renderCart();
      });
    });
  }

  // Handle Form Submission
  const form = document.getElementById('quotation-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = (document.getElementById('client-name') as HTMLInputElement).value;
    const email = (document.getElementById('client-email') as HTMLInputElement).value;
    const company = (document.getElementById('client-company') as HTMLInputElement).value;
    const address = (document.getElementById('client-address') as HTMLInputElement).value;
    const phone = (document.getElementById('client-phone') as HTMLInputElement).value;
    const notes = (document.getElementById('client-notes') as HTMLTextAreaElement).value;

    const cart = getCart();
    if (cart.length === 0) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const quotationData = {
      name,
      email,
      company,
      company_address: address,
      phone,
      notes,
      items: cart, // Save items list as dynamic json array
    };

    try {
      // Dynamic import to prevent bundler resolution collisions on initial page load
      const PocketBase = (await import('pocketbase')).default;
      const pb = new PocketBase(import.meta.env.PUBLIC_POCKETBASE_URL || 'http://127.0.0.1:8090');
      await pb.collection('quotations').create(quotationData);
      console.log('Quotation successfully stored in PocketBase.');
    } catch (err) {
      console.warn("PocketBase collection 'quotations' not found or unreachable. Falling back to simulation.", err);
    } finally {
      // Reset cart
      saveCart([]);

      // Transition to success layout
      document.getElementById('cart-container')?.classList.add('hidden');
      document.getElementById('cart-success-state')?.classList.remove('hidden');
    }
  });

  // Initial draw
  renderCart();
</script>
