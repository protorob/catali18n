---
import Layout from "../../../layouts/Layout.astro";
import { pb } from "../../../lib/pocketbase";
import { getTranslations } from "../../../lib/translations";

const { locale = "it", slug } = Astro.params;
const t = getTranslations(locale);

let product: any = null;
let categorySlug = "";
let categoryName = "";
let localePaths: Record<string, string> = {};

try {
  const langRecord = await pb
    .collection("languages")
    .getFirstListItem(`code="${locale}"`);

  const prodI18n = await pb
    .collection("products_i18n")
    .getFirstListItem(`slug="${slug}" && language="${langRecord.id}"`, {
      expand: "record,record.category",
    });

  const baseRecord = prodI18n.expand?.record;

  product = {
    id: baseRecord?.id || prodI18n.id,
    prod_name: prodI18n.prod_name,
    prod_description: prodI18n.prod_description,
    slug: prodI18n.slug,
    sku: baseRecord?.product_sku,
    ean: baseRecord?.product_ean,
    mainImageUrl: baseRecord?.product_main_image
      ? pb.files.getURL(baseRecord, baseRecord.product_main_image)
      : null,
    galleryImageUrls: (baseRecord?.product_gallery_images ?? []).map(
      (img: string) => pb.files.getURL(baseRecord, img),
    ),
    // Product dimensions & weight
    width_cm: baseRecord?.product_width_cm || null,
    length_cm: baseRecord?.product_lenght_cm || null,
    height_cm: baseRecord?.product_height_cm || null,
    weight_kg: baseRecord?.product_weight_kg || null,
    net_weight_kg: baseRecord?.product_net_w_kg || null,
    per_box: baseRecord?.product_per_box || null,
    // Carton dimensions & weight
    box_width_cm: baseRecord?.box_width_cm || null,
    box_length_cm: baseRecord?.box_lenght_cm || null,
    box_height_cm: baseRecord?.box_height_cm || null,
    box_weight_kg: baseRecord?.box_weight_kg || null,
  };

  // Localized category
  const baseCategory = baseRecord?.expand?.category;
  if (baseCategory) {
    const catI18n = await pb
      .collection("categories_i18n")
      .getFirstListItem(
        `record="${baseCategory.id}" && language="${langRecord.id}"`,
      );
    categoryName = catI18n.name;
    categorySlug = catI18n.slug;
  }

  // Build per-locale paths for the language switcher
  const allProdI18n = await pb.collection("products_i18n").getFullList({
    filter: `record="${product.id}"`,
    expand: "language",
  });
  for (const p of allProdI18n) {
    const code = p.expand?.language?.code;
    if (code) localePaths[code] = `/${code}/product/${p.slug}`;
  }
} catch (err) {
  console.warn(
    "PocketBase unreachable or product not found. Using fallback mock details.",
  );

  if (slug === "plc-controller-h100") {
    product = {
      id: "fallback_p1",
      prod_name: "PLC Controller H100",
      prod_description:
        locale === "it"
          ? "Il PLC Controller H100 è un controllore logico programmabile progettato per l'automazione industriale. Supporta fino a 128 moduli di espansione e integra protocolli Ethernet/IP, Modbus TCP e RTU."
          : "The PLC Controller H100 is a programmable logic controller for industrial automation. Supports up to 128 expansion modules and integrates Ethernet/IP, Modbus TCP and RTU protocols.",
      slug,
      sku: "PLC-H100-XYZ",
      ean: "8012345678901",
      mainImageUrl: null,
      galleryImageUrls: [],
      width_cm: 45,
      length_cm: 30,
      height_cm: 12,
      weight_kg: 3.2,
      net_weight_kg: 2.8,
      per_box: 4,
      box_width_cm: 50,
      box_length_cm: 35,
      box_height_cm: 28,
      box_weight_kg: 14.0,
    };
    categoryName =
      locale === "it" ? "Elettronica Industriale" : "Industrial Electronics";
    categorySlug = "electronics";
  } else if (slug === "laser-sensor-l20") {
    product = {
      id: "fallback_p2",
      prod_name: "Laser Distance Sensor L20",
      prod_description:
        locale === "it"
          ? "Sensore di distanza laser industriale ad alta precisione. Misurazioni stabili fino a 20m con accuratezza millimetrica."
          : "High-precision industrial laser distance sensor. Stable measurements up to 20m with millimeter accuracy.",
      slug,
      sku: "SEN-L20-LAS",
      ean: "8012345678902",
      mainImageUrl: null,
      galleryImageUrls: [],
      width_cm: 8,
      length_cm: 5,
      height_cm: 3,
      weight_kg: 0.2,
      net_weight_kg: 0.15,
      per_box: 20,
      box_width_cm: 30,
      box_length_cm: 20,
      box_height_cm: 15,
      box_weight_kg: 4.5,
    };
    categoryName =
      locale === "it" ? "Elettronica Industriale" : "Industrial Electronics";
    categorySlug = "electronics";
  } else {
    product = {
      id: "fallback_generic",
      prod_name: slug?.replace(/-/g, " ") ?? "Product",
      prod_description: "",
      slug,
      sku: null,
      ean: null,
      mainImageUrl: null,
      galleryImageUrls: [],
      width_cm: null,
      length_cm: null,
      height_cm: null,
      weight_kg: null,
      net_weight_kg: null,
      per_box: null,
      box_width_cm: null,
      box_length_cm: null,
      box_height_cm: null,
      box_weight_kg: null,
    };
  }
}

if (!product) return Astro.redirect(`/${locale}`);

const allImages: string[] = [
  product.mainImageUrl,
  ...product.galleryImageUrls,
].filter(Boolean);
const hasDimensions =
  product.width_cm && product.length_cm && product.height_cm;
const hasBoxDimensions =
  product.box_width_cm && product.box_length_cm && product.box_height_cm;
const hasSpecs =
  product.sku ||
  product.ean ||
  hasDimensions ||
  product.weight_kg ||
  product.per_box;
---

<Layout
  title={product.prod_name}
  description={product.prod_description?.replace(/<[^>]*>/g, "") || ""}
  localePaths={localePaths}
>
  <div class="py-8">
    <!-- Breadcrumbs -->
    <nav
      class="flex mb-8 text-xs font-semibold text-gray-500 uppercase tracking-wider"
      aria-label="Breadcrumb"
    >
      <a href={`/${locale}`} class="hover:text-brand-primary transition-colors"
        >Home</a
      >
      <span class="mx-2 text-gray-400">/</span>
      {
        categorySlug ? (
          <>
            <a
              href={`/${locale}/category/${categorySlug}`}
              class="hover:text-brand-primary transition-colors"
            >
              {categoryName}
            </a>
            <span class="mx-2 text-gray-400">/</span>
          </>
        ) : null
      }
      <span class="text-gray-700 dark:text-gray-300">{product.prod_name}</span>
    </nav>

    <!-- Product layout: image left, details right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Left: image viewer -->
      <div class="flex flex-col gap-4">
        <!-- Main image carousel (Swiper) — click slide to open lightbox -->
        <div
          class="relative rounded-2xl overflow-hidden border border-app-border/40"
          id="main-image-wrap"
        >
          {
            allImages.length > 0 ? (
              <div class="swiper" id="main-swiper">
                <div class="swiper-wrapper">
                  {allImages.map((url: string) => (
                    <div class="swiper-slide flex items-center justify-center min-h-80 md:min-h-[28rem] p-4 cursor-zoom-in">
                      <img
                        src={url}
                        alt={product.prod_name}
                        class="max-h-[28rem] max-w-full object-contain"
                        loading="lazy"
                      />
                    </div>
                  ))}
                </div>
                {allImages.length > 1 && (
                  <>
                    <div class="swiper-button-prev" id="main-prev" />
                    <div class="swiper-button-next" id="main-next" />
                  </>
                )}
              </div>
            ) : (
              <div class="flex items-center justify-center min-h-80 md:min-h-[28rem]">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="0.8"
                  stroke="currentColor"
                  class="w-32 h-32 text-gray-400 dark:text-gray-600"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"
                  />
                </svg>
              </div>
            )
          }
        </div>

        <!-- Thumbnail strip — visible when 2+ images -->
        {
          allImages.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-1">
              {allImages.map((url: string, i: number) => (
                <button
                  class:list={[
                    "gallery-thumb shrink-0 w-20 h-20 rounded-xl overflow-hidden border-2 transition-colors hover:border-brand-primary",
                    i === 0 ? "border-brand-primary" : "border-transparent",
                  ]}
                  data-index={i}
                >
                  <img
                    src={url}
                    alt={`${product.prod_name} ${i + 1}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </button>
              ))}
            </div>
          )
        }
      </div>

      <!-- Right: details -->
      <div class="flex flex-col gap-6">
        <!-- SKU / category badges -->
        <div class="flex items-center flex-wrap gap-2">
          {
            product.sku && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300">
                {product.sku}
              </span>
            )
          }
          {
            categorySlug && (
              <a
                href={`/${locale}/category/${categorySlug}`}
                class="text-xs font-medium text-gray-500 hover:text-brand-primary transition-colors"
              >
                {t.product.category}: {categoryName}
              </a>
            )
          }
        </div>

        <!-- Description -->
        {
          product.prod_description && (
            <div class="text-gray-600 dark:text-gray-400 font-light leading-relaxed">
              {product.prod_description.startsWith("<") ? (
                <Fragment set:html={product.prod_description} />
              ) : (
                <p>{product.prod_description}</p>
              )}
            </div>
          )
        }

        <!-- Specs table -->
        {
          hasSpecs && (
            <div>
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-500 mb-3">
                {t.product.specifications}
              </h2>
              <table class="w-full text-sm border-collapse">
                <tbody>
                  {product.sku && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium w-1/2">
                        {t.product.sku}
                      </td>
                      <td class="py-2.5 font-mono font-semibold text-app-fg">
                        {product.sku}
                      </td>
                    </tr>
                  )}
                  {product.ean && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.ean}
                      </td>
                      <td class="py-2.5 font-mono font-semibold text-app-fg">
                        {product.ean}
                      </td>
                    </tr>
                  )}
                  {hasDimensions && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.dimensions}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.width_cm} × {product.length_cm} ×{" "}
                        {product.height_cm} cm
                      </td>
                    </tr>
                  )}
                  {product.weight_kg && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.grossWeight}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.weight_kg} kg
                      </td>
                    </tr>
                  )}
                  {product.net_weight_kg && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.netWeight}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.net_weight_kg} kg
                      </td>
                    </tr>
                  )}
                  {product.per_box && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.unitsPerCarton}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.per_box}
                      </td>
                    </tr>
                  )}
                  {hasBoxDimensions && (
                    <tr class="border-b border-app-border/40">
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.cartonDimensions}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.box_width_cm} × {product.box_length_cm} ×{" "}
                        {product.box_height_cm} cm
                      </td>
                    </tr>
                  )}
                  {product.box_weight_kg && (
                    <tr>
                      <td class="py-2.5 pr-4 text-gray-500 font-medium">
                        {t.product.cartonWeight}
                      </td>
                      <td class="py-2.5 font-semibold text-app-fg">
                        {product.box_weight_kg} kg
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          )
        }

        <!-- Add to quote CTA -->
        <div
          class="bg-app-bg border border-app-border/60 rounded-2xl p-6 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-4 mt-auto"
        >
          <div class="flex items-center space-x-3">
            <label
              for="quantity-selector"
              class="text-xs font-semibold uppercase tracking-wider text-gray-500"
            >
              {t.product.quantity}
            </label>
            <div
              class="flex items-center border border-app-border rounded-xl overflow-hidden bg-app-card"
            >
              <button
                id="qty-decrement"
                class="p-2.5 hover:bg-app-bg text-gray-500 font-bold transition-colors"
                >&minus;</button
              >
              <input
                id="quantity-selector"
                type="number"
                value="1"
                min="1"
                class="w-12 text-center bg-transparent border-none text-sm font-semibold focus:outline-hidden"
              />
              <button
                id="qty-increment"
                class="p-2.5 hover:bg-app-bg text-gray-500 font-bold transition-colors"
                >&plus;</button
              >
            </div>
          </div>

          <button
            id="add-to-quote-btn"
            class="flex-grow sm:flex-grow-0 px-6 py-3.5 bg-brand-primary hover:bg-brand-hover text-white text-sm font-semibold rounded-xl transition-all shadow-md active:scale-95 flex items-center justify-center space-x-2"
            data-id={product.id}
            data-name={product.prod_name}
            data-sku={product.sku}
            data-added-label={t.product.added}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 4.5v15m7.5-7.5h-15"></path>
            </svg>
            <span>{t.product.addToQuote}</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Data for client script -->
  <div
    id="product-images-data"
    class="hidden"
    data-images={JSON.stringify(allImages)}
  >
  </div>

  <!-- Lightbox — images stacked absolutely, one visible at a time via opacity toggle.
       No Swiper: avoids all container-measurement timing issues. -->
  {
    allImages.length > 0 && (
      <div
        id="lightbox"
        class="fixed inset-0 z-[200] flex flex-col bg-black/95 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-150"
        role="dialog"
        aria-modal="true"
      >
        <div class="flex items-center justify-between px-4 py-3 shrink-0">
          <span id="lightbox-counter" class="text-white/60 text-sm tabular-nums" />
          <button
            id="lightbox-close"
            class="text-white/70 hover:text-white transition-colors p-2 rounded-lg hover:bg-white/10"
            aria-label="Close"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Stage: all images stacked, CSS opacity switches which is visible -->
        <div class="relative flex-1 min-h-0" id="lightbox-stage">
          {allImages.map((url: string, i: number) => (
            <div
              class="absolute inset-0 flex items-center justify-center p-4 md:p-10 transition-opacity duration-200"
              data-lb-index={i}
              style={i === 0 ? "opacity:1" : "opacity:0;pointer-events:none"}
            >
              <img
                src={url}
                alt={product.prod_name}
                class="max-h-full max-w-full object-contain select-none"
                draggable="false"
              />
            </div>
          ))}
          {allImages.length > 1 && (
            <>
              <button
                id="lb-prev"
                class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-lg bg-black/45 backdrop-blur-sm flex items-center justify-center text-white hover:bg-black/70 transition-colors"
                aria-label="Previous"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
              </button>
              <button
                id="lb-next"
                class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-lg bg-black/45 backdrop-blur-sm flex items-center justify-center text-white hover:bg-black/70 transition-colors"
                aria-label="Next"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            </>
          )}
        </div>

        <div class="flex gap-2 justify-center py-3 px-4 shrink-0 overflow-x-auto">
          {allImages.map((url: string, i: number) => (
            <button
              class="lightbox-thumb shrink-0 w-14 h-14 rounded-lg overflow-hidden transition-opacity"
              style={i === 0 ? "opacity:1" : "opacity:0.45"}
              data-index={i}
            >
              <img src={url} alt="" class="w-full h-full object-cover" draggable="false" />
            </button>
          ))}
        </div>
      </div>
    )
  }
</Layout>

<script>
  import Swiper from "swiper";
  import { Navigation, Keyboard } from "swiper/modules";

  const images: string[] = JSON.parse(
    document.getElementById("product-images-data")?.dataset.images ?? "[]",
  );

  // Main image Swiper — always visible, no dimension issues
  let mainSwiper: Swiper | null = null;
  if (images.length > 0) {
    mainSwiper = new Swiper("#main-swiper", {
      modules: [Navigation, Keyboard],
      navigation: { prevEl: "#main-prev", nextEl: "#main-next" },
      keyboard: { enabled: true, onlyInViewport: true },
      on: {
        slideChange() {
          syncPageThumbs(mainSwiper!.activeIndex);
        },
      },
    });

    // Click a slide (not nav buttons) to open lightbox
    document
      .querySelectorAll<HTMLElement>("#main-swiper .swiper-slide")
      .forEach((slide, i) => {
        slide.addEventListener("click", () => openLightbox(i));
      });
  }

  // Thumbnail strip — slides main Swiper, does NOT open lightbox
  const thumbBtns =
    document.querySelectorAll<HTMLButtonElement>(".gallery-thumb");

  function syncPageThumbs(activeIndex: number) {
    thumbBtns.forEach((b, i) => {
      b.classList.toggle("border-brand-primary", i === activeIndex);
      b.classList.toggle("border-transparent", i !== activeIndex);
    });
  }

  thumbBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = parseInt(btn.dataset.index ?? "0");
      mainSwiper?.slideTo(idx);
      syncPageThumbs(idx);
    });
  });

  // Lightbox — no Swiper, pure opacity-toggle between absolutely-stacked slides
  const lightbox = document.getElementById("lightbox");
  const counter = document.getElementById("lightbox-counter");
  const lbSlides = document.querySelectorAll<HTMLElement>("[data-lb-index]");
  const lbThumbs = document.querySelectorAll<HTMLButtonElement>(".lightbox-thumb");
  let lbIndex = 0;

  function showLbSlide(index: number) {
    lbIndex = (index + images.length) % images.length;
    lbSlides.forEach((s, i) => {
      const active = i === lbIndex;
      s.style.opacity = active ? "1" : "0";
      // Use "" (inherit) for the active slide so the lightbox parent's pointer-events
      // class controls interactivity — avoids the active slide overriding pointer-events-none
      // on the closed lightbox and eating Swiper clicks through the transparent overlay.
      s.style.pointerEvents = active ? "" : "none";
    });
    lbThumbs.forEach((b, i) => {
      b.style.opacity = i === lbIndex ? "1" : "0.45";
    });
    if (counter) counter.textContent = `${lbIndex + 1} / ${images.length}`;
  }

  function openLightbox(index: number) {
    if (!lightbox) return;
    lightbox.classList.remove("opacity-0", "pointer-events-none");
    showLbSlide(index);
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.add("opacity-0", "pointer-events-none");
  }

  document.getElementById("lb-prev")?.addEventListener("click", () => showLbSlide(lbIndex - 1));
  document.getElementById("lb-next")?.addEventListener("click", () => showLbSlide(lbIndex + 1));
  lbThumbs.forEach((btn) => btn.addEventListener("click", () => showLbSlide(parseInt(btn.dataset.index ?? "0"))));

  // Drag/swipe on the stage — pointerdown/pointerup covers both desktop mouse and mobile touch
  const lbStage = document.getElementById("lightbox-stage");
  let lbPointerX = 0;
  lbStage?.addEventListener("pointerdown", (e) => { lbPointerX = e.clientX; }, { passive: true });
  lbStage?.addEventListener("pointerup", (e) => {
    const delta = lbPointerX - e.clientX;
    if (Math.abs(delta) > 50) showLbSlide(delta > 0 ? lbIndex + 1 : lbIndex - 1);
  });

  document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
  // Close when clicking the dark area around the image (the slide div, not the img inside it)
  lbSlides.forEach((slide) => slide.addEventListener("click", (e) => { if (e.target === slide) closeLightbox(); }));
  document.addEventListener("keydown", (e) => {
    if (lightbox?.classList.contains("opacity-0")) return;
    if (e.key === "ArrowLeft") showLbSlide(lbIndex - 1);
    if (e.key === "ArrowRight") showLbSlide(lbIndex + 1);
    if (e.key === "Escape") closeLightbox();
  });

  // Quantity selector
  const qtyInput = document.getElementById(
    "quantity-selector",
  ) as HTMLInputElement;
  document.getElementById("qty-decrement")?.addEventListener("click", () => {
    const v = parseInt(qtyInput.value) || 1;
    if (v > 1) qtyInput.value = String(v - 1);
  });
  document.getElementById("qty-increment")?.addEventListener("click", () => {
    qtyInput.value = String((parseInt(qtyInput.value) || 1) + 1);
  });

  // Add to quote
  const addBtn = document.getElementById("add-to-quote-btn");
  addBtn?.addEventListener("click", () => {
    const id = addBtn.getAttribute("data-id");
    const name = addBtn.getAttribute("data-name");
    const sku = addBtn.getAttribute("data-sku");
    const qty = parseInt(qtyInput.value) || 1;
    if (!id || !name) return;
    try {
      const cart = JSON.parse(localStorage.getItem("cart") || "[]");
      const idx = cart.findIndex((item: any) => item.id === id);
      if (idx > -1) {
        cart[idx].quantity += qty;
      } else {
        cart.push({ id, name, sku, quantity: qty });
      }
      localStorage.setItem("cart", JSON.stringify(cart));
      window.dispatchEvent(new Event("cart-updated"));
      const span = addBtn.querySelector("span");
      if (span) {
        const orig = span.textContent;
        span.textContent = `✓ ${addBtn.getAttribute("data-added-label") || "Added"}`;
        addBtn.classList.replace("bg-brand-primary", "bg-emerald-600");
        addBtn.classList.replace(
          "hover:bg-brand-hover",
          "hover:bg-emerald-700",
        );
        setTimeout(() => {
          span.textContent = orig;
          addBtn.classList.replace("bg-emerald-600", "bg-brand-primary");
          addBtn.classList.replace(
            "hover:bg-emerald-700",
            "hover:bg-brand-hover",
          );
        }, 1500);
      }
      qtyInput.value = "1";
    } catch (e) {
      console.error("Cart error", e);
    }
  });
</script>

