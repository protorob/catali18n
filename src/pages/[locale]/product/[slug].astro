---
import Layout from '../../../layouts/Layout.astro';
import { pb } from '../../../lib/pocketbase';
import { getTranslations } from '../../../lib/translations';

const { locale = 'it', slug } = Astro.params;
const t = getTranslations(locale);

let product = null;
let categorySlug = '';
let categoryName = '';

try {
  // 1. Fetch language record
  const langRecord = await pb.collection('languages').getFirstListItem(`code="${locale}"`);

  // 2. Fetch localized product details
  const prodI18n = await pb.collection('products_i18n').getFirstListItem(
    `slug="${slug}" && language="${langRecord.id}"`,
    { expand: 'record,record.category' }
  );

  product = {
    id: prodI18n.expand?.record?.id || prodI18n.id,
    name: prodI18n.name || prodI18n.prod_title,
    prod_title: prodI18n.prod_title,
    prod_description: prodI18n.prod_description,
    sku: prodI18n.expand?.record?.product_sku,
    ean: prodI18n.expand?.record?.product_ean,
  };

  // Get localized category info if available
  const baseCategory = prodI18n.expand?.record?.expand?.category;
  if (baseCategory) {
    const catI18n = await pb.collection('categories_i18n').getFirstListItem(
      `record="${baseCategory.id}" && language="${langRecord.id}"`
    );
    categoryName = catI18n.name;
    categorySlug = catI18n.slug;
  }
} catch (err) {
  console.warn("PocketBase unreachable or product not found. Using fallback mock details.");
  
  // High fidelity fallbacks for standard products
  if (slug === 'plc-controller-h100') {
    product = {
      id: 'fallback_p1',
      name: 'PLC Controller H100',
      prod_title: 'Programmable Logic Controller H100',
      prod_description: locale === 'it' 
        ? 'Il PLC Controller H100 è un controllore logico programmabile progettato per l\'automazione industriale di medie e grandi dimensioni. Supporta fino a 128 moduli di espansione, integra protocolli di comunicazione Ethernet/IP, Modbus TCP e RTU, ed è conforme allo standard IEC 61131-3.' 
        : 'The PLC Controller H100 is a programmable logic controller engineered for mid-to-large scale industrial automation. It supports up to 128 expansion modules, integrates Ethernet/IP, Modbus TCP and RTU communication protocols, and complies with the IEC 61131-3 standard.',
      sku: 'PLC-H100-XYZ',
      ean: '8012345678901'
    };
    categoryName = locale === 'it' ? 'Elettronica Industriale' : 'Industrial Electronics';
    categorySlug = 'electronics';
  } else if (slug === 'laser-sensor-l20') {
    product = {
      id: 'fallback_p2',
      name: 'Sensore Laser L20',
      prod_title: 'Laser Distance Sensor L20',
      prod_description: locale === 'it'
        ? 'Sensore di distanza laser industriale ad alta precisione. Offre misurazioni stabili fino a 20 metri con un livello millimetrico di accuratezza, ideale per la rilevazione di posizione nei magazzini automatici.'
        : 'High-precision industrial laser distance sensor. Delivers stable measurements up to 20 meters with millimeter-level accuracy, ideal for position detection in automated warehouses.',
      sku: 'SEN-L20-LAS',
      ean: '8012345678902'
    };
    categoryName = locale === 'it' ? 'Elettronica Industriale' : 'Industrial Electronics';
    categorySlug = 'electronics';
  } else if (slug === 'analog-modulator-m40') {
    product = {
      id: 'fallback_p3',
      name: 'Modulatore Analogico M40',
      prod_title: 'Analog Signal Modulator M40',
      prod_description: locale === 'it'
        ? 'Modulatore e convertitore di segnale analogico industriale. Converte segnali standard 0-10V o 4-20mA in stringhe Modbus RS485 digitali, riducendo le interferenze e facilitando la diagnostica remota.'
        : 'Industrial analog signal modulator and converter. Converts standard 0-10V or 4-20mA signals into digital Modbus RS485 strings, reducing interference and facilitating remote diagnostics.',
      sku: 'MOD-M40-ANA',
      ean: '8012345678903'
    };
    categoryName = locale === 'it' ? 'Elettronica Industriale' : 'Industrial Electronics';
    categorySlug = 'electronics';
  } else if (slug === 'pneumatic-actuator-p5') {
    product = {
      id: 'fallback_p4',
      name: 'Pistone Pneumatico P5',
      prod_title: 'Pneumatic Actuator P5',
      prod_description: locale === 'it'
        ? 'Attuatore pneumatico a doppio effetto ad alte prestazioni. Costruito con corpo in alluminio anodizzato e guarnizioni resistenti alle alte temperature, garantisce oltre 10 milioni di cicli operativi.'
        : 'High performance double-acting pneumatic actuator. Engineered with an anodized aluminum body and high-temperature resistant seals, guaranteeing over 10 million operating cycles.',
      sku: 'ACT-P5-PNEU',
      ean: '8012345678904'
    };
    categoryName = locale === 'it' ? 'Attrezzature & Macchinari' : 'Equipment & Machinery';
    categorySlug = 'machinery';
  }
}

if (!product) {
  return Astro.redirect(`/${locale}`);
}
---

<Layout title={product.name} description={product.prod_description.replace(/<[^>]*>/g, '')}>
  <div class="py-6">
    
    <!-- Breadcrumbs -->
    <nav class="flex mb-8 text-xs font-semibold text-gray-500 uppercase tracking-wider" aria-label="Breadcrumb">
      <a href={`/${locale}`} class="hover:text-brand-primary transition-colors">Home</a>
      <span class="mx-2 text-gray-400">/</span>
      {categorySlug ? (
        <>
          <a href={`/${locale}/category/${categorySlug}`} class="hover:text-brand-primary transition-colors">{categoryName}</a>
          <span class="mx-2 text-gray-400">/</span>
        </>
      ) : null}
      <span class="text-gray-700 dark:text-gray-300">{product.name}</span>
    </nav>

    <!-- Product Grid layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 bg-app-card border border-app-border/60 rounded-3xl p-8 md:p-12 shadow-md">
      
      <!-- Left: Visual Placeholder -->
      <div class="flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 rounded-2xl min-h-80 md:min-h-96 p-8 border border-app-border/40">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-32 h-32 text-gray-400 dark:text-gray-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
        </svg>
      </div>

      <!-- Right: Product Specifications -->
      <div class="flex flex-col justify-between">
        <div>
          <!-- Tags / Category -->
          <div class="flex items-center space-x-2 mb-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300">
              {product.sku}
            </span>
            {categorySlug ? (
              <a
                href={`/${locale}/category/${categorySlug}`}
                class="text-xs font-medium text-gray-500 hover:text-brand-primary transition-colors"
              >
                {t.product.category}: {categoryName}
              </a>
            ) : null}
          </div>

          <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-2">
            {product.prod_title || product.name}
          </h1>

          <div class="space-y-4 my-6 text-sm border-y border-app-border/40 py-4 text-gray-500">
            <div class="flex justify-between">
              <span>{t.product.sku}:</span>
              <span class="font-mono text-app-fg font-semibold">{product.sku}</span>
            </div>
            <div class="flex justify-between">
              <span>{t.product.ean}:</span>
              <span class="font-mono text-app-fg font-semibold">{product.ean}</span>
            </div>
          </div>

          <div class="text-gray-600 dark:text-gray-400 font-light leading-relaxed mb-8">
            {product.prod_description.startsWith('<') ? <Fragment set:html={product.prod_description} /> : <p>{product.prod_description}</p>}
          </div>
        </div>

        <!-- Call to action add to quote -->
        <div class="bg-app-bg border border-app-border/60 rounded-2xl p-6 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-4 mt-6">
          <div class="flex items-center space-x-3">
            <label for="quantity-selector" class="text-xs font-semibold uppercase tracking-wider text-gray-500">
              {t.product.quantity}
            </label>
            <div class="flex items-center border border-app-border rounded-xl overflow-hidden bg-app-card">
              <button id="qty-decrement" class="p-2.5 hover:bg-app-bg text-gray-500 font-bold transition-colors">&minus;</button>
              <input
                id="quantity-selector"
                type="number"
                value="1"
                min="1"
                class="w-12 text-center bg-transparent border-none text-sm font-semibold focus:outline-hidden"
              />
              <button id="qty-increment" class="p-2.5 hover:bg-app-bg text-gray-500 font-bold transition-colors">&plus;</button>
            </div>
          </div>

          <button
            id="add-to-quote-btn"
            class="flex-grow sm:flex-grow-0 px-6 py-3.5 bg-brand-primary hover:bg-brand-hover text-white text-sm font-semibold rounded-xl transition-all shadow-md active:scale-95 flex items-center justify-center space-x-2"
            data-id={product.id}
            data-name={product.name}
            data-sku={product.sku}
            data-added-label={t.product.added}
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            <span>{t.product.addToQuote}</span>
          </button>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  // Dynamic quantity selector adjustments
  const qtyInput = document.getElementById('quantity-selector') as HTMLInputElement;
  const decBtn = document.getElementById('qty-decrement');
  const incBtn = document.getElementById('qty-increment');

  decBtn?.addEventListener('click', () => {
    const val = parseInt(qtyInput.value) || 1;
    if (val > 1) {
      qtyInput.value = String(val - 1);
    }
  });

  incBtn?.addEventListener('click', () => {
    const val = parseInt(qtyInput.value) || 1;
    qtyInput.value = String(val + 1);
  });

  // LocalStorage cart mechanics
  const addBtn = document.getElementById('add-to-quote-btn');
  addBtn?.addEventListener('click', () => {
    const id = addBtn.getAttribute('data-id');
    const name = addBtn.getAttribute('data-name');
    const sku = addBtn.getAttribute('data-sku');
    const quantity = parseInt(qtyInput.value) || 1;

    if (!id || !name || !sku) return;

    try {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      
      // Check if product already in cart
      const existingItemIndex = cart.findIndex((item: any) => item.id === id);
      if (existingItemIndex > -1) {
        cart[existingItemIndex].quantity += quantity;
      } else {
        cart.push({ id, name, sku, quantity });
      }

      localStorage.setItem('cart', JSON.stringify(cart));
      
      // Dispatch custom event to notify layout menubar cart counter
      window.dispatchEvent(new Event('cart-updated'));

      // Toast feedback or quick micro animation
      const btnSpan = addBtn.querySelector('span');
      if (btnSpan) {
        const originalText = btnSpan.textContent;
        const addedLabel = addBtn.getAttribute('data-added-label') || 'Added';
        btnSpan.textContent = `✓ ${addedLabel}`;
        addBtn.classList.remove('bg-brand-primary', 'hover:bg-brand-hover');
        addBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-700');
        
        setTimeout(() => {
          btnSpan.textContent = originalText;
          addBtn.classList.remove('bg-emerald-600', 'hover:bg-emerald-700');
          addBtn.classList.add('bg-brand-primary', 'hover:bg-brand-hover');
        }, 1500);
      }

      // Reset qty selector back to 1
      qtyInput.value = "1";

    } catch (err) {
      console.error("Failed to add product to quotation cart", err);
    }
  });
</script>
